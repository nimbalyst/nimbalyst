{
  "name": "Nimbalyst Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-playwright.playwright"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "forwardPorts": [5273],
  "portsAttributes": {
    "5273": {
      "label": "Vite Dev Server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "Xvfb :99 -screen 0 1920x1080x24 &",
  "remoteEnv": {
    "DISPLAY": ":99",
    "PLAYWRIGHT": "1",
    "ELECTRON_DISABLE_SECURITY_WARNINGS": "1"
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspaces/nimbalyst,type=bind,consistency=cached",
    "target=/workspaces/nimbalyst/node_modules,type=volume",
    "target=/workspaces/nimbalyst/packages/electron/node_modules,type=volume",
    "target=/workspaces/nimbalyst/packages/runtime/node_modules,type=volume",
    "target=/workspaces/nimbalyst/packages/collabv3/node_modules,type=volume",
    "target=/workspaces/nimbalyst/packages/extension-sdk/node_modules,type=volume",
    "target=/workspaces/nimbalyst/packages/ios/node_modules,type=volume"
  ],
  "runArgs": [
    "--shm-size=2g",
    "--cap-add=SYS_ADMIN"
  ]
}
