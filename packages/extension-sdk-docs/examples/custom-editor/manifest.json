{
  "id": "com.example.json-viewer",
  "name": "JSON Viewer",
  "version": "1.0.0",
  "description": "A tree-view editor for JSON files with expand/collapse",
  "main": "dist/index.js",
  "styles": "dist/index.css",
  "apiVersion": "1.0.0",
  "permissions": {
    "filesystem": true,
    "ai": true
  },
  "contributions": {
    "customEditors": [
      {
        "filePatterns": ["*.jsonview"],
        "displayName": "JSON Tree Viewer",
        "component": "JsonViewer"
      }
    ],
    "aiTools": [
      "json.get_structure",
      "json.get_value",
      "json.set_value"
    ],
    "newFileMenu": [
      {
        "extension": ".jsonview",
        "displayName": "JSON View File",
        "icon": "data_object",
        "defaultContent": "{\n  \"name\": \"example\",\n  \"items\": []\n}"
      }
    ]
  }
}
