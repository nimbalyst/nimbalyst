{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@nimbalyst/runtime": ["../runtime/src/index.ts"],
      "@nimbalyst/runtime/*": ["../runtime/src/*"],
      "@nimbalyst/extension-sdk": ["../extension-sdk/src/index.ts"],
      "@nimbalyst/extension-sdk/*": ["../extension-sdk/src/*"]
    }
  },
  "include": [
    "src",
    "../electron/src/renderer/electron.d.ts",
    "../runtime/src/editor/types/*.d.ts"
  ]
}
