#!/bin/sh
set -eu

# Validate package-lock.json is in sync with every workspace package.json
# when the outgoing commits touch any manifest. This is exactly the check
# CI's `npm ci` performs; without it, lockfile drift is only discovered
# after pushing (2026-07-07 incident: npm 10/11 override-shape mismatch).
base=""

# Prefer an explicit push baseline, then the branch's real upstream. The local
# origin/main ref may lag long-lived integration branches by weeks, which makes
# every later push look as though it changed a manifest and needlessly reruns
# npm ci --dry-run. Invalid or unavailable candidates fall through safely.
if [ -n "${NIMBALYST_PUSH_BASE_REF:-}" ]; then
  base=$(git merge-base HEAD "$NIMBALYST_PUSH_BASE_REF" 2>/dev/null || true)
fi
if [ -z "$base" ]; then
  upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
  if [ -n "$upstream" ]; then
    base=$(git merge-base HEAD "$upstream" 2>/dev/null || true)
  fi
fi
if [ -z "$base" ]; then
  base=$(git merge-base HEAD origin/main 2>/dev/null || true)
fi
if [ -z "$base" ]; then
  base=$(git rev-parse HEAD~1)
fi
if ! git diff --quiet "$base" HEAD -- package-lock.json 'package.json' '*/package.json' 2>/dev/null; then
  echo "[pre-push] Manifest/lockfile changed; validating lockfile sync (npm ci --dry-run)..."
  if ! npm ci --dry-run >/dev/null 2>&1; then
    echo ""
    echo "[pre-push] ERROR: package-lock.json is out of sync with package.json."
    echo "[pre-push] Run 'npm install' (Node 24 / npm 11 -- see .nvmrc) and commit the lockfile."
    npm ci --dry-run 2>&1 | grep -E 'Invalid|Missing|EBADENGINE' | head -10
    exit 1
  fi
  echo "[pre-push] Lockfile in sync."
fi

echo "[pre-push] Checking override/dep sync..."
npm run check:override-sync

echo "[pre-push] Checking Vitest config routing..."
npm run check:vitest-config-routing

echo "[pre-push] Building typecheck prerequisites and running the full typecheck..."
npm run typecheck:prepush

echo "[pre-push] Verifying platform test-gate behavior..."
npm run test:prepush-gate

echo "[pre-push] Running non-provider unit tests (Windows: known-failing suites excluded, see docs/WINDOWS_PREPUSH_GATE.md)..."
node scripts/prepush-test-gate.mjs
